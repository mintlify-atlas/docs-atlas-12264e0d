  "keyFeatures": [
    "Vector search and embeddings for semantic search and RAG",
    "Hybrid search combining text, vector, and structured data",
    "Real-time indexing and serving with low latency",
    "Distributed query execution with ranking and grouping",
    "ML model integration (ONNX, TensorFlow, custom models)",
    "Tensor computation engine for advanced ranking",
    "Elastic and auto-recovering data storage",
    "Stateless container layer with custom component development",
    "Multi-tenancy and cloud deployment support",
    "Comprehensive query language (YQL) and APIs"
  ],
  "publicApiSurface": [
    "/document/v1/ - Document API for feeding and retrieving documents",
    "/search/ - Query API for searching and ranking",
    "Vespa CLI - Command-line tool for application deployment",
    "Java Searcher API - Custom search logic components",
    "Java Document Processor API - Document processing pipeline",
    "Java Component API - Dependency injection framework",
    "Feed Client API - High-performance feeding library",
    "Query Language (YQL) - SQL-like query syntax",
    "Ranking Expressions - Custom ranking functions",
    "Schema Definition Language - Document structure and indexing",
    "Config API - Application configuration system",
    "Tensor API - Tensor operations and computation"
  ]
